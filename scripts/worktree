#!/usr/bin/env bash
# scripts/worktree <name> — start a task: branch + worktree, caches wired.
# See CLAUDE.md "Branches and worktrees". Load-bearing rule: this must be
# near-free to run, or the discipline dies. Keep it fast.
set -euo pipefail

name="${1:?usage: scripts/worktree <branch-name>}"
root="$(git rev-parse --show-toplevel)"
trees="$root/.worktrees"

mkdir -p "$trees"
git -C "$root" worktree add -b "$name" "$trees/$name" main

# --- build-state wiring: ADAPT PER STACK, then delete this comment -------
# The goal: a fresh worktree is ready to run tests in seconds, not minutes.
# Examples:
#   pnpm     : nothing to do — the shared store makes `pnpm install` cheap
#   npm      : (cd "$trees/$name" && npm ci --prefer-offline)
#   cargo    : nothing to do — target dir can be shared via CARGO_TARGET_DIR
#   python   : (cd "$trees/$name" && uv sync)  # uv's cache makes this fast
# --------------------------------------------------------------------------

echo "worktree ready: $trees/$name"
